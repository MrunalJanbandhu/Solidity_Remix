		"devdoc": {
			"kind": "dev",
			"methods": {
				"constructor": {
					"params": {
						"_arbitrator": "Optional external arbitrator (pass address(0) to skip)",
						"_feeBps": "Initial fee in basis points (≤ 500)",
						"_treasury": "Address of deployed Treasury contract"
					}
				},
				"createOrder(address,bytes32)": {
					"params": {
						"detailsHash": "keccak256 of order metadata stored off-chain",
						"seller": "Seller's address (must hold ROLE_SELLER)"
					},
					"returns": {
						"orderId": "    ID of the newly created order"
					}
				},
				"fundOrder(uint256)": {
					"details": "msg.value becomes the locked escrow amount.         Transitions: Created → Funded"
				}
			},
			"stateVariables": {
				"_locked": {
					"details": "Manual reentrancy lock"
				}
			},
			"title": "EscrowMarketplace",
			"version": 1
		},
		"userdoc": {
			"kind": "user",
			"methods": {
				"arbitrator()": {
					"notice": "Optional external arbitrator (can be address(0))"
				},
				"calculateFee(uint256)": {
					"notice": "Calculate the fee for a given amount using current feeBps"
				},
				"cancelUnfunded(uint256)": {
					"notice": "Buyer cancels a Created (unfunded) order.         Transitions: Created → Cancelled"
				},
				"confirmReceived(uint256)": {
					"notice": "Buyer confirms delivery — releases funds to seller minus fee.         Transitions: Shipped → Completed"
				},
				"createOrder(address,bytes32)": {
					"notice": "Create a new order with an off-chain metadata hash."
				},
				"feeBps()": {
					"notice": "Fee in basis points (1 BPS = 0.01%).  Default 100 BPS = 1%"
				},
				"fundOrder(uint256)": {
					"notice": "Fund a Created order with the exact agreed ETH amount."
				},
				"getOrder(uint256)": {
					"notice": "Return full order data"
				},
				"grantRole(address,uint8)": {
					"notice": "Grant a role to an account (admin only)"
				},
				"hasRole(address,uint8)": {
					"notice": "Check whether `account` holds `role`"
				},
				"markShipped(uint256)": {
					"notice": "Seller marks the order as shipped.         Transitions: Funded → Shipped"
				},
				"openDispute(uint256)": {
					"notice": "Buyer opens a dispute (Funded or Shipped).         Transitions: Funded|Shipped → Disputed"
				},
				"refundBuyer(uint256)": {
